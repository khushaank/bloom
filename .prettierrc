# Bloom Finance - Prettier Configuration
# Code formatting rules for consistent style

{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "none",
  "bracketSpacing": true,
  "arrowParens": "always",
  "html": {
    "whitespaceSensitivity": "css"
  },
  "printWidth": 100,
  "proseWrap": "preserve"
}
