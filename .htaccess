# Apache Configuration for Bloom Finance
# Enables modern web features, security, and performance optimization

# Enable mod_rewrite
<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# Force HTTPS + non-www canonical URL (adjust target domain if needed)
RewriteCond % { HTTPS } !=on [OR]
RewriteCond % { HTTP_HOST } ^www\.(.+)$ [NC]
RewriteRule ^ https://% { HTTP_HOST }% { REQUEST_URI } [L, R=301]

# Clean URLs: serve paths without .html (only when .html exists)
RewriteCond % { REQUEST_FILENAME } !-f
RewriteCond % { REQUEST_FILENAME } !-d
RewriteCond % { REQUEST_FILENAME }.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Fallback for SPA-style routes (if you use client-side routing)
RewriteCond % { REQUEST_FILENAME } !-f
RewriteCond % { REQUEST_FILENAME } !-d
RewriteRule ^.*$ /index.html [L]
</IfModule>

# Custom Error Pages
ErrorDocument 404 /404.html
ErrorDocument 500 /500.html

# Security Headers
<IfModule mod_headers.c>
# Prevent MIME type sniffing
Header always set X-Content-Type-Options "nosniff"
  
# Enable XSS protection
Header always set X-XSS-Protection "1; mode=block"
  
# Clickjacking protection
Header always set X-Frame-Options "SAMEORIGIN"
  
# Content Security Policy
Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' https://cdn.jsdelivr.net https://fonts.googleapis.com 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https:"
  
# Referrer Policy
Header always set Referrer-Policy "strict-origin-when-cross-origin"
  
# Feature Policy / Permissions Policy
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), clipboard-write=(self)"
</IfModule>

# Gzip Compression
<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml+rss
AddEncoding gzip .gz
<IfModule mod_setenvif.c>
SetEnvIfNoCase Request_URI \.(?:gif | jpe?g | png)$ no-gzip
</IfModule>
</IfModule>

# Browser Caching
<IfModule mod_expires.c>
ExpiresActive On
ExpiresDefault                                      "access plus 2 days"
  
# HTML
ExpiresByType text/html                            "access plus 0 seconds"
  
# CSS
ExpiresByType text/css                             "access plus 1 day"
  
# JavaScript
ExpiresByType application/javascript               "access plus 1 day"
ExpiresByType text/javascript                      "access plus 1 day"
  
# Media
ExpiresByType image/jpeg                           "access plus 30 days"
ExpiresByType image/gif                            "access plus 30 days"
ExpiresByType image/png                            "access plus 30 days"
ExpiresByType image/webp                           "access plus 30 days"
ExpiresByType image/svg+xml                        "access plus 30 days"
  
# Fonts
ExpiresByType application/font-woff                "access plus 30 days"
ExpiresByType application/font-woff2               "access plus 30 days"
ExpiresByType application/vnd.ms-fontobject        "access plus 30 days"
ExpiresByType application/x-font-ttf               "access plus 30 days"
ExpiresByType font/opentype                        "access plus 30 days"
</IfModule>

# Disable directory listing
<IfModule mod_autoindex.c>
Options -Indexes
</IfModule>

# Block access to sensitive files
<FilesMatch "\.(env|json|config|sql|\.git|\.htaccess)$"
Require all denied
</FilesMatch>

# Set default charset
AddDefaultCharset UTF-8
